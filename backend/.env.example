# Production Environment Variables for Render / Netlify
# DO NOT COMMIT YOUR ACTUAL SECRETS

# --- DATABASE (Supabase) ---
DB_HOST=your-supabase-host
DB_USER=postgres.your-id
DB_PASS=your-password
DB_NAME=postgres
DB_PORT=6543
DB_SSL=true

# --- EXTERNAL SERVICES ---
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
TURNSTILE_SECRET_KEY=your-cloudflare-secret-key
GEMINI_API_KEY=your-google-gemini-key

# --- EMAIL (SMTP) ---
SMTP_HOST=mail.samalocation.com
SMTP_PORT=465
SMTP_USER=noreply@samalocation.com
SMTP_PASS=your-secure-password
SMTP_SECURE=true
SMTP_FROM=noreply@samalocation.com

# --- APPLICATION ---
FRONTEND_URL=https://samalocation.com
JWT_SECRET=generate-a-long-random-string-here
JWT_EXPIRES_IN=30d
NODE_ENV=production
PORT=5000
